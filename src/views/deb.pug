doctype html
html(lang=langCode)
  head
    title #{siteName} - #{lang.debTitle}
    meta(name='description', content=lang.debSubtitle)
    meta(name='keywords', content='electerm,debian,repository,apt,setup,install,linux,terminal,ssh')
    meta(property='og:title' content='electerm - Debian Repository Setup')
    meta(property='og:description' content=lang.debSubtitle)
    meta(name='twitter:title' content='electerm - Debian Repository Setup')
    meta(name='twitter:description' content=lang.debSubtitle)
    include ./parts/react-header
  body
    include ./parts/header

    section.deb-hero
      .container
        img.deb-hero-logo(src='https://electerm.org/electerm.png', alt='electerm')
        h1 #{lang.debTitle}
        p.deb-hero-tagline #{lang.debSubtitle}

    section.deb-features
      .container
        .section-header
          h2 #{lang.debWhyUse}
        .features-grid
          .feature-card
            .feature-icon 🔒
            h3 #{lang.debSecureVerifiedTitle}
            p #{lang.debSecureVerifiedDesc}
          .feature-card
            .feature-icon ⚡
            h3 #{lang.debAutoUpdatesTitle}
            p #{lang.debAutoUpdatesDesc}
          .feature-card
            .feature-icon 🏗️
            h3 #{lang.debX86SupportTitle}
            p #{lang.debX86SupportDesc}

    section.deb-steps
      .container
        .section-header
          h2 #{lang.debInstallation}
          p #{lang.debInstallationSubtitle}

        .steps-grid
          .step-card
            .step-number 1
            .step-content
              h3 #{lang.debAddRepository}
              p #{lang.debAddRepositoryDesc}

              .code-block
                button.copy-button(onclick="copyToClipboard(this)") #{lang.debCopy}
                pre.
                  # Add the GPG key
                  curl -fsSL https://repos.electerm.org/deb/public.key | sudo gpg --dearmor -o /usr/share/keyrings/electerm.gpg

                  # Add the repository
                  echo "deb [arch=amd64 signed-by=/usr/share/keyrings/electerm.gpg] https://repos.electerm.org/deb stable main" | sudo tee /etc/apt/sources.list.d/electerm.list

          .step-card
            .step-number 2
            .step-content
              h3 #{lang.debUpdateInstall}
              p #{lang.debUpdateInstallDesc}

              .code-block
                button.copy-button(onclick="copyToClipboard(this)") #{lang.debCopy}
                pre.
                  # Update package list
                  sudo apt update

                  # Install Electerm
                  sudo apt install electerm

        .deb-success
          .deb-success-icon ✅
          .deb-success-text
            h4 #{lang.debThatsIt}
            p #{lang.debThatsItDesc}

    section.deb-info
      .container
        .section-header
          h2 #{lang.debRepositoryDetails}

        .info-grid
          .info-card
            .info-card-label #{lang.debRepositoryUrl}
            .info-card-value https://repos.electerm.org/deb
          .info-card
            .info-card-label #{lang.debDistribution}
            .info-card-value stable
          .info-card
            .info-card-label #{lang.debComponent}
            .info-card-value main
          .info-card
            .info-card-label #{lang.debArchitecture}
            .info-card-value amd64
          .info-card
            .info-card-label #{lang.debGpgKey}
            .info-card-value
              a(href="public.key") #{lang.debDownloadPublicKey}

    section.deb-security
      .container
        .section-header
          h2 #{lang.debSecurityFeatures}

        .security-grid
          .security-card
            .security-icon 🔐
            h4 #{lang.debGpgSignedTitle}
            p #{lang.debGpgSignedDesc}
          .security-card
            .security-icon 🌐
            h4 #{lang.debHttpsTransportTitle}
            p #{lang.debHttpsTransportDesc}
          .security-card
            .security-icon 🤖
            h4 #{lang.debAutomatedUpdatesTitle}
            p #{lang.debAutomatedUpdatesDesc}
          .security-card
            .security-icon ✓
            h4 #{lang.debVerifiedPackagesTitle}
            p #{lang.debVerifiedPackagesDesc}

    include ./parts/footer
    include ./parts/react-footer

    script.
      function copyToClipboard(button) {
          const codeBlock = button.parentElement;
          const preElement = codeBlock.querySelector('pre');

          if (!preElement) {
              console.error('No pre element found');
              return;
          }

          const textToCopy = preElement.textContent || preElement.innerText;

          if (navigator.clipboard && window.isSecureContext) {
              navigator.clipboard.writeText(textToCopy).then(() => {
                  showCopySuccess(button);
              }).catch(err => {
                  console.error('Failed to copy using Clipboard API:', err);
                  fallbackCopyToClipboard(textToCopy, button);
              });
          } else {
              fallbackCopyToClipboard(textToCopy, button);
          }
      }

      function fallbackCopyToClipboard(text, button) {
          const textArea = document.createElement('textarea');
          textArea.value = text;
          textArea.style.position = 'fixed';
          textArea.style.left = '-999999px';
          textArea.style.top = '-999999px';
          document.body.appendChild(textArea);
          textArea.focus();
          textArea.select();

          try {
              const successful = document.execCommand('copy');
              if (successful) {
                  showCopySuccess(button);
              } else {
                  showCopyError(button);
              }
          } catch (err) {
              console.error('Fallback copy failed:', err);
              showCopyError(button);
          }

          document.body.removeChild(textArea);
      }

      function showCopySuccess(button) {
          const originalText = button.textContent;
          button.textContent = 'Copied!';
          button.classList.add('copied');

          setTimeout(() => {
              button.textContent = originalText;
              button.classList.remove('copied');
          }, 2000);
      }

      function showCopyError(button) {
          const originalText = button.textContent;
          button.textContent = 'Error';
          button.style.background = '#f8d7da';
          button.style.color = '#721c24';
          button.style.borderColor = '#f5c6cb';

          setTimeout(() => {
              button.textContent = originalText;
              button.style.background = '';
              button.style.color = '';
              button.style.borderColor = '';
          }, 2000);
      }
